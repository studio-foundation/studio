{
  "name": "@studio/contracts",
  "version": "0.1.0",
  "description": "Shared TypeScript types and interfaces for Studio v7",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
