{
  "name": "@studio/api",
  "version": "0.1.0",
  "description": "HTTP API for Studio v7",
  "type": "module",
  "main": "./dist/api.js",
  "types": "./dist/api.d.ts",
  "exports": {
    ".": {
      "import": "./dist/api.js",
      "types": "./dist/api.d.ts"
    },
    "./standalone": {
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "studio-api": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "studio",
    "api"
  ],
  "author": "Ariane Guay",
  "license": "ISC",
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@studio/contracts": "workspace:*",
    "@studio/engine": "workspace:*",
    "@studio/runner": "workspace:*",
    "better-sqlite3": "^9.0.0",
    "fastify": "^5.3.2",
    "js-yaml": "^4.1.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.2.3",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
