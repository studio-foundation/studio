{
  "name": "@studio/engine",
  "version": "0.2.0",
  "description": "Pipeline orchestration engine for Studio v7",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "keywords": ["studio", "engine", "pipeline", "orchestration"],
  "author": "Ariane Guay",
  "license": "ISC",
  "dependencies": {
    "@studio/contracts": "workspace:*",
    "@studio/ralph": "workspace:*",
    "@studio/runner": "workspace:*",
    "better-sqlite3": "^9.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/js-yaml": "^4.0.9",
    "typescript": "^5.3.0",
    "vitest": "^2.1.9"
  }
}
