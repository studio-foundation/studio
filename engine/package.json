{
  "name": "@studio-foundation/engine",
  "version": "0.5.2",
  "description": "Pipeline orchestration, state machine, and lifecycle hooks for Studio",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest --coverage"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "studio",
    "engine",
    "pipeline",
    "orchestration"
  ],
  "author": "Ariane Guay",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@studio-foundation/contracts": "workspace:*",
    "@studio-foundation/ralph": "workspace:*",
    "@studio-foundation/runner": "workspace:*",
    "better-sqlite3": "^9.0.0",
    "js-yaml": "^4.1.0",
    "pg": "^8.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/js-yaml": "^4.0.9",
    "@types/pg": "^8.18.0",
    "@types/node": "^25.2.3",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  }
}
